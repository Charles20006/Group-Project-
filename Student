public class Student extends Person {
    private static int counter = 1000;

    private String id;
    private StudentLinkedList courses; // Student schedule

    public Student(String name) {
        super(name);
        this.id = "S" + counter++;
        this.courses = new StudentLinkedList();
    }

    public String getId() {
        return id;
    }

    /**
     * Add a course to student's schedule
     */
    public void addCourse(Course c) {
        if (courses.findCourse(c.getCourseCode()) == null) {
            courses.addCourse(c);
        }
    }

    /**
     * Remove a course from schedule
     */
    public void removeCourse(String courseCode) {
        courses.removeCourse(courseCode);
    }

    /**
     * Display student schedule
     */
    public void displaySchedule() {
        System.out.println("\nSchedule for " + name + ":");
        courses.displayCourses();
    }

    @Override
    public String toString() {
        return name + " (" + id + ")";
    }
}
