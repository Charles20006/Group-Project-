public class Enrollment {

    /**
     * Register a student into a course
     */
    public static void enrollStudent(Student s, Course c) {

        if (c == null || s == null) {
            System.out.println("Invalid student or course.");
            return;
        }

        // Delegate to Course logic
        c.enroll(s);

    
        if (c.isEnrolled(s.getId())) {
            s.addCourse(c);
        }
    }

    /**
     * Drop a student from a course
     */
    public static void dropStudent(Student s, Course c) {

        if (c == null || s == null) {
            System.out.println("Invalid student or course.");
            return;
        }

        c.drop(s.getId());

        // Update student schedule
        s.removeCourse(c.getCourseCode());
    }

    /**
     * Check enrollment status
     */
    public static void checkEnrollment(Student s, Course c) {

        if (c.isEnrolled(s.getId())) {
            System.out.println(s.getName() + " is enrolled in " + c.getCourseCode());
        } else {
            System.out.println(s.getName() + " is NOT enrolled in " + c.getCourseCode());
        }
    }
}
